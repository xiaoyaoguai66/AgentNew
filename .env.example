# Runtime reads `.env` and `backend/.env`.
# `.env.example` is only a template for reference and should not contain real secrets.

APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

MYSQL_URL=mysql+aiomysql://root:your_password@localhost:3306/news_app?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0
VIEW_FLUSH_INTERVAL_SECONDS=60

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=qwen3-max-preview
LLM_REQUEST_TIMEOUT_SECONDS=60

TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=3
TAVILY_TIMEOUT_SECONDS=8

LOCAL_RETRIEVAL_ENGINE=lexical
ENABLE_VECTOR_RETRIEVAL=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=agentnews_news_chunks
QDRANT_TIMEOUT_SECONDS=5
# Leave QDRANT_URL empty to use local persistent mode under QDRANT_LOCAL_PATH.
QDRANT_LOCAL_PATH=backend/data/qdrant

# If EMBEDDING_* are left empty and LLM_BASE_URL points to DashScope-compatible chat,
# the backend will fall back to DashScope embeddings with model text-embedding-v4.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentnews-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
AGENT_RUN_LOG_PATH=backend/data/agent_runs/agent_runs.jsonl
AGENT_WORKFLOW_ENGINE=langgraph
AI_LOW_CONFIDENCE_THRESHOLD=0.58
AI_REFUSAL_CONFIDENCE_THRESHOLD=0.34
AI_SESSION_MEMORY_TTL_SECONDS=86400
AI_SESSION_RECENT_MESSAGE_LIMIT=6
AI_SESSION_SUMMARY_MAX_CHARS=900

NEWS_CHUNK_SIZE_CHARS=480
NEWS_CHUNK_OVERLAP_CHARS=80
VECTOR_INDEX_BATCH_SIZE=20
